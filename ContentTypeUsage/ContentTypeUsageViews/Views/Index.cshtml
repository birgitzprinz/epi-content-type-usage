@using EPiServer.Shell
@using EPiServer.Shell.Web.Mvc.Html
@using EPiServer.Framework.Web.Resources
@using ContentTypeUsage.ViewModels
@using EPiServer.Framework.Localization
@using EPiServer.Shell.Navigation
@using System.Text.Json
@addTagHelper *, EPiServer.Shell.UI

@model ContentTypeUsageViewModels

@{
    Layout = string.Empty;
    var styleCss = Paths.ToClientResource(typeof(ContentTypeUsageViewModels), "ClientResources/Styles/style.css");
    var bundleJs = Paths.ToClientResource(typeof(ContentTypeUsageViewModels), "ClientResources/Scripts/dist/app.bundle.js");

    var pageTypesJson = JsonSerializer.Serialize(
        Model.AllPageTypes.Select(t => new { value = t.Value, text = t.Text }));
    var blockTypesJson = JsonSerializer.Serialize(
        Model.AllBlockTypes.Select(t => new { value = t.Value, text = t.Text }));

    var ls = LocalizationService.Current;
    var labelsJson = JsonSerializer.Serialize(new
    {
        displayName              = ls.GetString("/plugins/contenttypeusage/displayname"),
        description              = ls.GetString("/plugins/contenttypeusage/description"),
        contentType              = ls.GetString("/plugins/contenttypeusage/contenttype"),
        filter                   = ls.GetString("/plugins/contenttypeusage/filter"),
        search                   = ls.GetString("/plugins/contenttypeusage/search"),
        close                    = ls.GetString("/plugins/contenttypeusage/close"),
        contentId                = ls.GetString("/plugins/contenttypeusage/contentId"),
        usages                   = ls.GetString("/plugins/contenttypeusage/usages"),
        name                     = ls.GetString("/plugins/contenttypeusage/name"),
        links                    = ls.GetString("/plugins/contenttypeusage/links"),
        edit                     = ls.GetString("/plugins/contenttypeusage/edit"),
        view                     = ls.GetString("/plugins/contenttypeusage/view"),
        references               = ls.GetString("/plugins/contenttypeusage/references"),
        editTooltip              = ls.GetString("/plugins/contenttypeusage/editTooltip"),
        viewTooltip              = ls.GetString("/plugins/contenttypeusage/viewTooltip"),
        referencesTooltip        = ls.GetString("/plugins/contenttypeusage/referencesTooltip"),
        contentInstanceSuggestions  = ls.GetString("/plugins/contenttypeusage/contentInstanceSuggestions"),
        modalDialogHeader        = ls.GetString("/plugins/contenttypeusage/modalDialogHeader"),
        contentReferencesSuggestions = ls.GetString("/plugins/contenttypeusage/contentReferencesSuggestions"),
        searchSuggestions        = ls.GetString("/plugins/contenttypeusage/searchSuggestions"),
        itemsCount               = ls.GetString("/plugins/contenttypeusage/itemsCount"),
        pageTypesHeading         = ls.GetString("/admin/menuheadings/pagetypes"),
        blockTypesHeading        = ls.GetString("/admin/menuheadings/blocktypes"),
    });
}

<!DOCTYPE html>
<html>
<head>
    <title>@ls.GetString("/plugins/contenttypeusage/displayname")</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link href="@styleCss" type="text/css" rel="stylesheet" />
</head>
<body class="epi-contentTypeUsage">
    @Html.CreatePlatformNavigationMenu()
    <platform-navigation />
    <noscript>You need to enable JavaScript to run this app.</noscript>
    <div class="epi-pn-navigation--fixed-adjust" @Html.ApplyPlatformNavigation()>
        <div class="content-area-container">
            <div id="content-type-usage-root" class="container-fluid"
                 data-page-types="@pageTypesJson"
                 data-block-types="@blockTypesJson"
                 data-labels="@labelsJson">
            </div>
        </div>
    </div>
    
    <script src="@bundleJs"></script>
    @ClientResources.RenderResources("admin", new[] { ClientResourceType.Script })
</body>
</html>
